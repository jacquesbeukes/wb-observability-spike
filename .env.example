# Copy this file to .env and fill in real values before running docker compose up.
# .env is gitignored — never commit real secrets.

# Grafana admin password for local access (Cognito handles auth in AWS)
GRAFANA_ADMIN_PASSWORD=changeme

# Sentry org-level read token — used by the Grafana Sentry datasource
# Create at: sentry.io → Settings → Auth Tokens (needs project:read scope)
SENTRY_ORG_TOKEN=
